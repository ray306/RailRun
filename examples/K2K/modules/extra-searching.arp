"""
补充信息获取 (extra-searching)
补充目标知识可能需要，但源知识中缺乏的重要信息。
"""

while True:
  # 嵌套调用 K2K 模型，**进行一次微型 K2K 分析**
  嵌套调用(
    sub_task="召唤擅长推理的【福尔摩斯🕵️】和擅长考据的【考据党🔎】，让他们联手根据“源知识&差距分析”的内容补充信息"，
    role = "福尔摩斯🕵️"和"考据党🔎")

  step:
      压力测试(defender="福尔摩斯🕵️"和"考据党🔎", debate_mode=True)

  step:
      审查目前的信息够不够填补差距？
  
  if 如果没有缺失: 
      break